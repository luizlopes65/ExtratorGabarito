# OCR Answer Sheet Extractor - Configuration
# Copy this file to .env and adjust the values as needed

# ============================================================
# INPUT/OUTPUT PATHS
# ============================================================

# Path to the input answer sheet image
IMAGE_PATH=examples/image.png

# Output CSV file path (without extension - will generate 3 files)
OUTPUT_CSV=resultados/resultado_gabarito_v3.csv

# Directory for debug images
DEBUG_DIR=debug/debug_gabarito_v3

# ============================================================
# TESSERACT OCR CONFIGURATION
# ============================================================

# Path to Tesseract executable
# macOS (Homebrew): /opt/homebrew/bin/tesseract
# Linux: /usr/bin/tesseract
# Windows: C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_CMD=/opt/homebrew/bin/tesseract

# OCR language(s) - use + to combine multiple languages
OCR_LANG=por+eng

# ============================================================
# GRID DETECTION PARAMETERS
# ============================================================

# Minimum expected number of question columns
# If OCR detects fewer question columns than this, the system will use
# a fallback strategy and treat all columns (except the first name column)
# as question columns. This prevents missing questions due to OCR failures.
# Set to 8 for typical answer sheets with at least 8 questions.
MIN_EXPECTED_QUESTION_COLS=8

# Minimum expected number of student rows
# If fewer valid student rows are detected, the system will use the last
# N rows as a fallback to ensure some data is extracted even if name OCR fails.
MIN_EXPECTED_STUDENT_ROWS=3

# Maximum rotation correction in degrees
MAX_ROTATION_CORRECTION_DEGREES=8

# Tolerance for clustering grid line positions (pixels)
GRID_CLUSTER_TOLERANCE=12

# Minimum row height to be considered valid (pixels)
ROW_HEIGHT_MIN=30

# Minimum column width to be considered valid (pixels)
COL_WIDTH_MIN=25

# Expected number of questions (leave empty for auto-detection)
EXPECTED_NUM_QUESTIONS=

# ============================================================
# BUBBLE DETECTION PARAMETERS
# ============================================================

# Minimum fill density to consider a bubble as marked (0.0-1.0)
# Adjust between 0.03 and 0.08 based on print quality
MIN_FILL_DENSITY=0.05

# Minimum intensity difference between best and second option
# Below this threshold, cell is considered blank (tie)
MIN_INNER_DIFF=5

# Maximum ratio between second and first density for double marking
MAX_SECOND_RATIO=0.65

# ============================================================
# PROFILING VERSION SETTINGS
# ============================================================

# Number of parallel workers for OCR processing
OCR_MAX_WORKERS=4

# Enable debug image generation (true/false)
ENABLE_DEBUG_IMAGES=false

# Enable detailed profiling metrics (true/false)
PROFILE_DETAILED=false